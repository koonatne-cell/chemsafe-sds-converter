# คัดลอกไฟล์นี้เป็นชื่อ .env แล้วใส่ค่าจริงของคุณ (ห้าม commit ไฟล์ .env ตัวจริง)

# รหัสผู้ดูแล (Admin) ตั้งเองเป็นอะไรก็ได้ที่จำง่ายแต่คนอื่นเดาไม่ถูก
ADMIN_PASSCODE=changeme123

# กุญแจลับสำหรับเข้ารหัส session cookie ตั้งเป็นข้อความยาวๆ สุ่มๆ ก็พอ
SECRET_KEY=change-this-to-a-random-long-string

# Google Cloud Translation API key (ถ้ายังไม่มี ปล่อยว่างไว้ได้
# ระบบจะใช้ไลบรารีแปลฟรี deep-translator แทนโดยอัตโนมัติ)
GOOGLE_TRANSLATE_API_KEY=
